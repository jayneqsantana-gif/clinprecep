# Copie para app/.env (local) e/ou defina nas Environment Variables da Vercel.

# --- Cliente (expostas ao browser; NÃO são segredos) ---
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica

# --- Servidor (função /api/chat; NUNCA expostas ao browser) ---
# A chave da Anthropic fica só no servidor.
ANTHROPIC_API_KEY=
# Usadas para validar o token do usuário antes de chamar a IA:
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-publica
# Modelo padrão (opcional): claude-sonnet-5 | claude-opus-4-8 | claude-haiku-4-5
CLINPRECEP_MODEL=claude-sonnet-5
